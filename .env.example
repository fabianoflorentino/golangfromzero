# Database Configuration
DB_HOST=database
DB_PORT=5432
DB_USER=golangfromzero
DB_PASSWORD=golangfromzero
DB_NAME=golangfromzero
DB_SSLMODE=disable

# Connection Pool Settings
DB_MAX_CONNECTIONS=25
DB_MIN_CONNEXTIONS=5
DB_MAX_CONNECTION_LIFETIME=5m
DB_MAX_CONNECTION_IDLETIME=1m
DB_HEALTHCHECK_PERIOD=1m

# Application Timeouts
DATABASE_TIMEOUT=5s
API_TIMEOUT=2s

# Server Configuration
SERVER_PORT=8080
LOG_LEVEL=info